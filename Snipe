local function FindAllPets()
	if not SniperActive then return end

	for _, boothInfo in pairs(data.Booths) do
		task.wait(0.05)
		local ownerId = boothInfo.Owner
		if not ownerId or not data.Players[ownerId] then continue end

		local ownerPlayer = TradeBoothData.getPlayerById(ownerId)
		if not ownerPlayer then continue end

		local playerListings = data.Players[ownerId].Listings
		if not playerListings then continue end

		local playerItems = data.Players[ownerId].Items
		if not playerItems then continue end

		for listingID, listingData in pairs(playerListings) do
			task.wait(0.01)
			if listingData.ItemType == "Pet" then
				local petData = playerItems[listingData.ItemId]
				if not petData then continue end

				local petName = petData.PetType or petData.Name or "Unknown Pet"

				PetUUID = listingData.ItemId
				PlayerName = ownerPlayer.Name
				PetPrice = listingData.Price
				PetName = petName
				PetListingID = listingID

				CheckKg()
				BuyPet()

				print(string.format(
					"Owner: %s | Pet: %s | Pet UUID: %s | Listing ID: %s | Price: %s",
					ownerPlayer.Name,
					petName,
					listingData.ItemId,
					listingID,
					listingData.Price
					))
			end
		end
	end
end


