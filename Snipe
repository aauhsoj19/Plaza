local function WalkToBooth()
	if not Humanoid then return end

	if Following == true then return end

	if not PlayerBooth then return end

	local BoothWalk = PlayerBooth.CFrame * CFrame.new(-10, 0, 0).Position

	if not BoothWalk then return end
	local StartPos = Character:WaitForChild("Torso").Position
	if not StartPos then return end

	local BoothPath = PathFindingService:CreatePath()
	BoothPath:ComputeAsync(StartPos, BoothWalk)
	local Waypoints = BoothPath:GetWaypoints()

	for _, Waypoint in ipairs(Waypoints) do
		Walking = true

		if Waypoint.Action == Enum.PathWaypointAction.Jump then
			Humanoid:ChangeState(Enum.HumanoidStateType.Jumping)
		end

		Humanoid:MoveTo(Waypoint.Position)
		Humanoid.MoveToFinished:Wait()

	end
	Walking = false
	task.wait(0.5)
	Dance()
end


local function PointAndWalk()

	Humanoid:UnequipTools()
	Humanoid:ChangeState(Enum.HumanoidStateType.Jumping)
	local PlayerCharacterTable = game:GetService("Players"):GetPlayers()

	local Point = "rbxassetid://128853357"
	local StartPos = Character:FindFirstChild("Torso").Position

	local RandomPlayer = PlayerCharacterTable[math.random(1, #PlayerCharacterTable)]
	local RandomTorsoPosition = (RandomPlayer.Character.Torso.CFrame * CFrame.new(3, 0, 0)).Position

	if not RandomTorsoPosition then warn("NOooooo no worky") end

	local CharacterPath = PathFindingService:CreatePath()
	CharacterPath:ComputeAsync(StartPos, RandomTorsoPosition)

	local Waypoints = CharacterPath:GetWaypoints()

	if Walking == true then return end

	for _, Waypoint in ipairs(Waypoints) do
		Following = true
		if Waypoint.Action == Enum.PathWaypointAction.Jump then
			Humanoid:ChangeState(Enum.HumanoidStateType.Jumping)
		end

		Humanoid:MoveTo(Waypoint.Position)
		Humanoid.MoveToFinished:Wait()
	end

	local Pointing = Instance.new("Animation")
	Pointing.AnimationId = Point

	local PointTrack = Character:FindFirstChild("Humanoid"):LoadAnimation(Pointing)
	PointTrack.Looped = false
	PointTrack:Play()

	GlobalAnimation = PointTrack

	PointTrack.Stopped:Connect(function()
		Humanoid:ChangeState(Enum.HumanoidStateType.Jumping)
		Following = false
		WalkToBooth()
	end)
end



local function GetClosestPlayers()
	ClosestCharacter = nil
	ClosestDistance = math.huge
	local VariableOfDistance

	if Touching == false then
		VariableOfDistance = 7
	else
		VariableOfDistance = 20
	end

	local Character = Player.Character or Player.CharacterAdded:Wait()
	if not Character then return end

	local HRP = Character:WaitForChild("HumanoidRootPart")
	if not HRP then return end

	for _, RPlayer in pairs(Players:GetPlayers()) do
		if RPlayer ~= Players.LocalPlayer and RPlayer.Character and RPlayer.Character:FindFirstChild("HumanoidRootPart") then
			local CharacterPosition = RPlayer.Character.HumanoidRootPart.Position
			local Distance = (CharacterPosition - HRP.Position).Magnitude

			if Distance < ClosestDistance and Distance < VariableOfDistance then
				ClosestDistance = Distance
				ClosestCharacter = RPlayer

				local StareAt = Vector3.new(CharacterPosition.X, HRP.Position.Y, CharacterPosition.Z)

				HRP.CFrame = CFrame.new(HRP.Position, StareAt)
			end
		end
		HDistance = ClosestDistance
	end
end



