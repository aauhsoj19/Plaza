local PetFinderToggle = Tabs.PetFinder:AddToggle("PetFinderToggle", {Title = "Pet Finder Toggle", Default = false })

PetFinderToggle:OnChanged(function()
	local Running = PetFinderToggle.Value
	if Running then
		Found = false
		task.spawn(function()
			while Running do
				task.wait(300)
				SeenListings = {}
				print("♻️ Cleared seen listings cache")
			end
		end)
		task.spawn(function()
			while Running do
				if not ExoticPet1 then return end
				task.wait(10)
				args[2].PetData.BaseWeight = StartingWeight
				print("🔍 Searching listings...")

				local success, listingId = game:GetService("ReplicatedStorage")
					:WaitForChild("GameEvents")
					:WaitForChild("TradeEvents")
					:WaitForChild("TokenRAPs")
					:WaitForChild("FindSellers")
					:InvokeServer(unpack(args))

				if not success or type(listingId) ~= "string" then
					print("Adjusted Weight:", StartingWeight)
					if MinimumWeight == MaximumWeight or StartingWeight <= 0 then continue end
					if StartingWeight == MinimumWeight then
						WeightStep = 0.1
					elseif StartingWeight == MaximumWeight then
						WeightStep = -0.1
					end
					StartingWeight = StartingWeight + WeightStep
					StartingWeight = math.floor(StartingWeight * 10 + 0.5) / 10
					continue
				end

				if SeenListings[listingId] then
					print("⚠️ Already seen ListingId:", listingId)
					continue
				end
				SeenListings[listingId] = true

				Found = true
				print("✅ MATCH FOUND! ListingId:", listingId)
				print("Pet:", args[2].PetType, "| Weight:", args[2].PetData.BaseWeight * 10)

				task.wait(5)
				game:GetService("ReplicatedStorage")
					:WaitForChild("GameEvents")
					:WaitForChild("TradeEvents")
					:WaitForChild("TokenRAPs")
					:WaitForChild("TeleportToListing")
					:InvokeServer(listingId)
			end
		end)
	else
		Found = true
	end

end)

