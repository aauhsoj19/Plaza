local Gui  = nil
local Button = nil
local LastPlace

local Icon = RunService.Heartbeat:Connect(function()
	if Window.Minimized == true and Gui == nil and Button == nil then


		Gui = Instance.new("ScreenGui")
		Gui.Name = "FloatingToggle"
		Gui.ResetOnSpawn = false
		Gui.Parent = LocalPlayer:WaitForChild("PlayerGui")
		local ScreenType


		Button = Instance.new("ImageButton")
		if UIS.TouchEnabled and not UIS.KeyboardEnabled and not UIS.MouseEnabled then 
			ScreenType = UDim2.fromOffset(35, 35)
		else
			ScreenType = UDim2.fromOffset(100, 100)
		end
		Button.Size = ScreenType
		Button.Position = LastPlace or UDim2.fromScale(0.5, 0.5)
		Button.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
		Button.BorderSizePixel = 0
		Button.Parent = Gui
		Button.BackgroundTransparency = 0
		Button.ScaleType = Enum.ScaleType.Fit
		Button.Image = "rbxassetid://12169663385"
		Button.ImageTransparency = 0


		local Corner = Instance.new("UICorner")
		Corner.CornerRadius = UDim.new(0.2, 0)
		Corner.Parent = Button


		local dragging = false
		local dragStart, startPos

		Button.InputBegan:Connect(function(input)
			if input.UserInputType == Enum.UserInputType.MouseButton1
				or input.UserInputType == Enum.UserInputType.Touch then
				dragging = true
				dragStart = input.Position
				startPos = Button.Position
			end
		end)

		Button.InputEnded:Connect(function(input)
			if input.UserInputType == Enum.UserInputType.MouseButton1
				or input.UserInputType == Enum.UserInputType.Touch then
				dragging = false
				Window:Minimize()
			end
		end)

		UIS.InputChanged:Connect(function(input)
			if dragging and (
				input.UserInputType == Enum.UserInputType.MouseMovement
					or input.UserInputType == Enum.UserInputType.Touch
				) then
				local delta = input.Position - dragStart
				Button.Position = UDim2.new(
					startPos.X.Scale,
					startPos.X.Offset + delta.X,
					startPos.Y.Scale,
					startPos.Y.Offset + delta.Y
				)
				LastPlace = Button.Position
			end
		end)

	elseif Window.Minimized == false and Gui and Button then
		Gui:Destroy()
		Button:Destroy()
		Gui = nil
		Button = nil

	end

end)


